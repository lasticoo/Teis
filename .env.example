# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=teis_user
DB_PASSWORD=teis_secure_pass
DB_NAME=teis_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO (S3-compatible) Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=teis_minio_admin
MINIO_SECRET_KEY=teis_minio_secret_pass
MINIO_BUCKET_NAME=teis-screenshots

# Security & Secrets
SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
AES_ENCRYPTION_KEY=generate_32_byte_aes_key_base64_here

# Binance API Configuration (Testnet defaults)
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_API_SECRET=your_binance_testnet_api_secret
BINANCE_USE_TESTNET=true
