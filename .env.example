# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=teis_user
DB_PASSWORD=teis_secure_pass
DB_NAME=teis_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO (S3-compatible) Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=teis_minio_admin
MINIO_SECRET_KEY=teis_minio_secret_pass
MINIO_BUCKET_NAME=teis-screenshots

# Security & Secrets
SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
AES_ENCRYPTION_KEY=generate_32_byte_aes_key_base64_here

# Binance API Configuration (Testnet defaults)
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_API_SECRET=your_binance_testnet_api_secret
BINANCE_USE_TESTNET=true

# Notification Configuration (SMTP & Web Push VAPID)
SMTP_HOST=your_smtp_host
SMTP_PORT=your_smtp_port
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com

VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_ADMIN_EMAIL=admin@yourdomain.com
